# ----------------------------------------------------------------------------
# Shipwrecked Pools - Root Environment Template
# Placeholders only. Do not store real secrets in this file.
# ----------------------------------------------------------------------------

# App environment
APP_ENV=development
APP_NAME=shipwrecked-pools-app

# API URLs
API_BASE_URL=http://localhost:4000
ADMIN_BASE_URL=http://localhost:3000
MOBILE_PUBLIC_API_URL=http://localhost:4000

# Database (server-only)
DATABASE_URL=postgres://username:password@localhost:5432/shipwrecked_dev

# Auth (server-only)
AUTH_SECRET=replace-with-long-random-secret
AUTH_ISSUER=shipwrecked-local

# Storage placeholders
STORAGE_PROVIDER=local
STORAGE_BUCKET=shipwrecked-local-assets

# Stripe/payment placeholders (server-only)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Push notification placeholders
PUSH_NOTIFICATION_PROJECT_ID=replace-with-project-id

# SMS/email fallback placeholders (server-only)
SMS_PROVIDER=twilio_placeholder
SMS_PROVIDER_API_KEY=replace_me
EMAIL_PROVIDER=resend_placeholder
EMAIL_PROVIDER_API_KEY=replace_me

# Error monitoring/logging placeholders
ERROR_MONITORING_DSN=https://examplePublicKey@example.ingest.local/12345
LOG_LEVEL=debug

# Feature flags placeholders
FEATURE_FLAG_TECH_PREVIEW=false
FEATURE_FLAG_ADMIN_EXPERIMENTS=false

# Local development placeholders
LOCAL_TIMEZONE=America/Chicago
LOCAL_UPLOAD_DIR=./tmp/uploads
