{
  "name": "shipwrecked-pools-app",
  "version": "0.1.0",
  "private": true,
  "description": "Shipwrecked Pools customer, technician, admin, reporting, routing, billing, and pool-care app.",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "install:deps": "pnpm install",
    "dev": "echo \"Run one workspace app at a time: pnpm dev:mobile | pnpm dev:admin | pnpm dev:api\"",
    "dev:mobile": "pnpm --filter @shipwrecked/mobile dev",
    "dev:admin": "pnpm --filter @shipwrecked/admin dev",
    "dev:api": "pnpm --filter @shipwrecked/api dev",
    "build": "pnpm -r --if-present build",
    "build:mobile": "pnpm --filter @shipwrecked/mobile build",
    "build:admin": "pnpm --filter @shipwrecked/admin build",
    "build:api": "pnpm --filter @shipwrecked/api build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run",
    "doctor": "node scripts/doctor.mjs",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "clean": "pnpm -r --if-present clean",
    "docs:status": "cat docs/prompt-packs/STATUS_BOARD.md",
    "seed:demo": "echo \"S01-014 placeholder only: no executable DB seed runner yet. See packages/db/seeds/README.md\""
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "eslint": "^9.16.0",
    "globals": "^15.12.0",
    "prettier": "^3.4.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.16.0",
    "vitest": "^2.1.8"
  }
}
